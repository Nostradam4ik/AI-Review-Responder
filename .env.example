# Database
DATABASE_URL=postgresql+psycopg://reviewuser:reviewpass@postgres:5432/reviewdb
POSTGRES_USER=reviewuser
POSTGRES_PASSWORD=reviewpass
POSTGRES_DB=reviewdb

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback

# Groq AI
GROQ_API_KEY=your-groq-api-key
LLM_PROVIDER=groq

# Security
# SECRET_KEY must be 32+ chars. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production-must-be-32-chars-minimum

# CORS — set to your real domain(s) in production
ALLOWED_ORIGINS=["http://localhost:3000"]

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Frontend
FRONTEND_URL=https://your-domain.com

# Production
DOMAIN=your-domain.com

# Sentry error tracking (optional — leave empty to disable)
SENTRY_DSN=
