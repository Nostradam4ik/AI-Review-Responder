# ============================================================
# REQUIRED — app will not start without these
# ============================================================
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/reviewdb
SECRET_KEY=                    # python -c "import secrets; print(secrets.token_hex(32))"
EMAIL_SECRET_KEY=              # python -c "import secrets; print(secrets.token_hex(32))"
GOOGLE_CLIENT_ID=              # from console.cloud.google.com → OAuth 2.0 Client
GOOGLE_CLIENT_SECRET=          # from console.cloud.google.com → OAuth 2.0 Client
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback

# ============================================================
# REQUIRED FOR REVENUE (billing will fail without these)
# ============================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...   # Dashboard → Products → Starter → price ID
STRIPE_PRICE_ID_PRO=price_...       # Dashboard → Products → Pro → price ID
STRIPE_PRICE_ID_AGENCY=price_...    # Dashboard → Products → Agency → price ID

# ============================================================
# STRONGLY RECOMMENDED FOR PRODUCTION
# ============================================================

# Encrypts Google OAuth tokens stored in DB — REQUIRED for production security
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

GROQ_API_KEY=                  # from console.groq.com → API Keys
TELEGRAM_BOT_TOKEN=            # from @BotFather on Telegram
RESEND_API_KEY=                # from resend.com → API Keys

# Optional — leave empty to disable error tracking
SENTRY_DSN=

FRONTEND_URL=https://yourdomain.com
ENVIRONMENT=production         # development | production
DOMAIN=yourdomain.com          # used by nginx for SSL cert

# ============================================================
# FRONTEND (create frontend/.env.local)
# ============================================================
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
